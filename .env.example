PICOVOICE_ACCESS_KEY=<your-picovoice-access-key>

# Story 2.2: Talker fast-path LLM keys. Set ONLY the key for the
# provider configured in `setup.toml` `[talker] provider = "..."`.
# Storing all three is also fine — only the active one is read.
#
# Sprint-change-proposal-2026-05-12 (cloud STT default): GROQ_API_KEY is
# now ALSO required by the STT backend (`[stt] backend = "groq"` is the
# v1 default). One key serves both surfaces. If you flip
# `[stt] backend = "whisper-cpu"`, you can leave GROQ_API_KEY blank
# (the on-device STT path needs no key).
#
# OpenAI. https://platform.openai.com/api-keys
OPENAI_API_KEY=<your-openai-api-key>
# Groq — required for v1 STT default (and for Talker if provider="groq").
# https://console.groq.com/keys
GROQ_API_KEY=<your-groq-api-key>
# Gemini. https://aistudio.google.com/apikey
# GEMINI_API_KEY=<your-gemini-api-key>

# Story 2.3: Cartesia Sonic-3 streaming TTS. Get a key from
# https://play.cartesia.ai/. Charged per character synthesized;
# Sonic-3 is Cartesia's flagship voice model (~200-400 ms TTFB).
CARTESIA_API_KEY=<your-cartesia-api-key>

# Wired in Epic 5 Story 5.3 (only when daemon URL is non-localhost):
# DAEMON_BEARER_TOKEN=<shared-secret>
